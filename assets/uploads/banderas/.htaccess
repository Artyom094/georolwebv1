# Allow image uploads - serve directly
<IfModule mod_authz_core.c>
    # Apache 2.4+
    Require all granted
</IfModule>
<IfModule !mod_authz_core.c>
    # Apache 2.2
    Allow from all
</IfModule>

# Allow these image types
<FilesMatch "\.(jpg|jpeg|png|gif|webp|bmp|svg)$">
    <IfModule mod_authz_core.c>
        Require all granted
    </IfModule>
</FilesMatch>

# Prevent PHP execution in uploads directory (security)
<FilesMatch "\.php$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Deny from all
    </IfModule>
</FilesMatch>
